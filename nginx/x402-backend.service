[Unit]
Description=x402 Demo Backend
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/x402-playground/backend
ExecStart=/opt/x402-playground/backend/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
